# ─────────────────────────────────────────────────────────────────────────
# LLM PROVIDER — choose ONE option below
# ─────────────────────────────────────────────────────────────────────────

# OpenAI toggle (set true only when using OpenAI)
OPENAI_ENABLED=false

# Option A: OpenAI (cloud, costs money)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini          # gpt-4o-mini is cheapest for dev

# Option B: Ollama (fully local, free)
# 1. Install Ollama: https://ollama.ai
# 2. Run: ollama pull llama3.2
# 3. Run: ollama pull nomic-embed-text
USE_OLLAMA=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─────────────────────────────────────────────────────────────────────────
# GITHUB — required
# Create token at: https://github.com/settings/tokens
# Required scopes: repo (read), pull_requests (read)
# ─────────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=dev_secret_change_in_production

# ─────────────────────────────────────────────────────────────────────────
# JIRA — optional (leave blank to skip ticket fetching)
# ─────────────────────────────────────────────────────────────────────────
JIRA_ENABLED=false
JIRA_SERVER=https://yourcompany.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=

# ─────────────────────────────────────────────────────────────────────────
# LOCAL STORAGE PATHS
# ─────────────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
SQLITE_DB_PATH=./data/release_agent.db

# ─────────────────────────────────────────────────────────────────────────
# AGENT BEHAVIOUR
# ─────────────────────────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=10
HITL_RISK_THRESHOLD=0.75     # risk score >= this triggers human review pause
CONFIDENCE_THRESHOLD=0.65

# ─────────────────────────────────────────────────────────────────────────
# SLACK — optional (leave blank to print results to console instead)
# ─────────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# ─────────────────────────────────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
INTERNAL_API_KEY=dev-api-key    # used for GET /review/pending endpoint
